{
  "description": "hooksmith — routes all Claude Code events through hooksmith.json config",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 30 }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 30 }]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 30 }]
      }
    ],
    "PostToolBatch": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 30 }]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "FileChanged": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 30 }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 60 }]
      }
    ],
    "StopFailure": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 30 }]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 30 }]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 60 }]
      }
    ],
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 30 }]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "UserPromptExpansion": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "Notification": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 30 }]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 30 }]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "PreCompact": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "PostCompact": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 60 }]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "Elicitation": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ],
    "ElicitationResult": [
      {
        "hooks": [{ "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/dispatcher.js", "timeout": 15 }]
      }
    ]
  }
}
